# ==============================================================================
# Luci — Environment Variable Manifest
# ==============================================================================
# This file is the single authoritative reference for every env var consumed by
# either service. See data-model.md §2 for validation rules.
# Copy to .env.local and fill with real values: make bootstrap does this.
# ==============================================================================

# --- Profile & Service IDs ---
LUCI_ENV=local
SPRING_PROFILES_ACTIVE=local

# --- Database (Spring — JDBC) ---
LUCI_DB_URL=jdbc:postgresql://localhost:5432/luci
LUCI_DB_USER=luci
LUCI_DB_PASSWORD=luci

# --- Database (Python — libpq/psycopg) ---
LUCI_DB_DSN=postgresql://luci:luci@localhost:5432/luci

# --- Cache (both services) ---
LUCI_REDIS_URL=redis://localhost:6379/0

# --- M2M JWT Auth ---
LUCI_M2M_ISSUER=python-agent.luci.app
LUCI_M2M_AUDIENCE=finance-api.luci.app
LUCI_M2M_KID=luci-m2m-0000000000
LUCI_M2M_PRIVATE_KEY_PEM=REPLACE_ME_WITH_make_bootstrap
LUCI_M2M_PUBLIC_KEY_PEM=REPLACE_ME_WITH_make_bootstrap
LUCI_M2M_JWKS_URL=http://localhost:8080/.well-known/jwks.json

# --- Inter-service ---
SPRING_BASE_URL=http://localhost:8080

# --- Observability ---
LUCI_LOG_LEVEL=INFO
