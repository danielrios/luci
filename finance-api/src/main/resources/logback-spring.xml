<?xml version="1.0" encoding="UTF-8"?>
<!-- Logback configuration for Luci Finance API
     Uses logstash-logback-encoder for structured JSON output.
     All log events are field-tagged for downstream PiiRedactor compatibility.
     (FR-026a, Constitution §II, R-9) -->
<configuration>
    <springProperty scope="context" name="LOG_LEVEL" source="logging.level.root" defaultValue="INFO"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <includeMdcKeyName>traceId</includeMdcKeyName>
            <includeMdcKeyName>userId</includeMdcKeyName>
            <includeMdcKeyName>intent</includeMdcKeyName>
            <customFields>{"service":"finance-api"}</customFields>
            <timestampPattern>yyyy-MM-dd'T'HH:mm:ss.SSS'Z'</timestampPattern>
            <timeZone>UTC</timeZone>
        </encoder>
    </appender>

    <root level="${LOG_LEVEL}">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
